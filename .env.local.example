# Copy this file to .env.local and fill in your values
# .env.local is gitignored — never commit real secrets

# Your Anthropic API key (from console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# A strong passphrase only you know — protects the /admin generation page
ADMIN_PASSPHRASE=your-secret-passphrase-here

# GitHub personal access token with Contents: Read & Write on this repo
# Create at: github.com/settings/tokens → Fine-grained → this repo → Contents: Read+Write
GITHUB_TOKEN=github_pat_...

# Your GitHub repo in owner/repo format
GITHUB_REPO=vidarsveen/conceptlib
